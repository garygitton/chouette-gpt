{
  "manifest_version": 3,
  "name": "Chouette GPT",
  "version": "1.1.0",
  "description": "Assistant IA local et privé s'exécutant sur votre GPU via WebGPU et compagnon natif.",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {},
  "web_accessible_resources": [
    {
      "resources": [
        "dist/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
