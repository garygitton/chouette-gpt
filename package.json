{
  "name": "chouette-gpt",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:gh-pages": "cross-env NUXT_APP_BASE_URL=/chouette-gpt/ nuxt generate",
    "deploy": "pnpm run build:gh-pages && gh-pages -a --dotfiles -d .output/public",
    "dev": "nuxt dev",
    "dev:local": "cross-env HOST=chouette-gpt.localhost nuxt dev",
    "dev:log": "cross-env node scripts/dev-logger.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:ui": "playwright test --project=ui-tests",
    "test:gpu": "playwright test --project=webgpu-tests",
    "clean": "rimraf .nuxt .output dist node_modules pnpm-lock.yaml && pnpm install",
    "download-models": "node scripts/download-models.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lucide/vue": "^1.23.0",
    "@pinia/nuxt": "^1.0.1",
    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "comlink": "^4.4.2",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.6",
    "marked-katex-extension": "^5.1.2",
    "mermaid": "^11.4.1",
    "pinia": "^4.0.2",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@huggingface/hub": "^2.13.3",
    "@nuxt/devtools": "^4.0.0-alpha.7",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.61.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "3.15.2",
    "prettier": "^3.9.5",
    "puppeteer": "^25.3.0",
    "rimraf": "^6.1.3",
    "serve": "^14.2.4",
    "shadcn-nuxt": "^2.7.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.48.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
