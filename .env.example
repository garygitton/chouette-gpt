# Port sur lequel le serveur de dev Nuxt tourne
PORT=3000

# URL de base pour l'application et les tests Playwright
BASE_URL=http://localhost:3000/

# Optionnel: Limiter le nombre de workers (utile si vous manquez de RAM locale)
# PLAYWRIGHT_WORKERS=1
